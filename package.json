{
  "name": "itsaagent",
  "version": "0.3.0",
  "description": "ItsAAgent — Ollama-optimised ReAct agent for the CLI. Think, plan, execute on local hardware.",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "bin": {
    "iaa": "dist/index.js"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ink": "^5.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.17",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
